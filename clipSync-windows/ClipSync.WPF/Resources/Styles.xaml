<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ClipSync "Fluid Tech" 主题色板 -->
    <!-- 主色调 - 霓虹青绿品牌色 -->
    <SolidColorBrush x:Key="PrimaryColor" Color="#3DDC84"/>
    <SolidColorBrush x:Key="PrimaryLightColor" Color="#5FE8A0"/>
    <SolidColorBrush x:Key="PrimaryDarkColor" Color="#2BB968"/>
    <SolidColorBrush x:Key="PrimaryGlowColor" Color="#403DDC84"/>
    
    <!-- 辅助色 - 电光蓝 -->
    <SolidColorBrush x:Key="SecondaryColor" Color="#00D4FF"/>
    <SolidColorBrush x:Key="SecondaryLightColor" Color="#33DDFF"/>
    <SolidColorBrush x:Key="SecondaryDarkColor" Color="#00A8CC"/>
    
    <!-- 深色主题背景 - 深空蓝黑 -->
    <SolidColorBrush x:Key="BackgroundColor" Color="#0A0E17"/>
    <SolidColorBrush x:Key="SurfaceColor" Color="#111827"/>
    <SolidColorBrush x:Key="SurfaceElevatedColor" Color="#1A2332"/>
    <SolidColorBrush x:Key="SurfaceHighColor" Color="#243447"/>
    
    <!-- 文字颜色 -->
    <SolidColorBrush x:Key="TextColor" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="TextSecondaryColor" Color="#94A3B8"/>
    <SolidColorBrush x:Key="TextMutedColor" Color="#64748B"/>
    
    <!-- 边框和分割线 -->
    <SolidColorBrush x:Key="BorderColor" Color="#1E293B"/>
    <SolidColorBrush x:Key="BorderLightColor" Color="#334155"/>
    <SolidColorBrush x:Key="DividerColor" Color="#1AE2E8F0"/>
    
    <!-- 状态色 -->
    <SolidColorBrush x:Key="SuccessColor" Color="#3DDC84"/>
    <SolidColorBrush x:Key="ErrorColor" Color="#FF4757"/>
    <SolidColorBrush x:Key="ErrorLightColor" Color="#FF6B7A"/>
    <SolidColorBrush x:Key="WarningColor" Color="#FFAA00"/>
    <SolidColorBrush x:Key="WarningLightColor" Color="#FFCC44"/>

    <!-- 现代圆角 -->
    <CornerRadius x:Key="SmallRadius">8</CornerRadius>
    <CornerRadius x:Key="MediumRadius">12</CornerRadius>
    <CornerRadius x:Key="LargeRadius">16</CornerRadius>
    <CornerRadius x:Key="XLargeRadius">24</CornerRadius>

    <!-- 阴影效果 -->
    <DropShadowEffect x:Key="CardShadow" Color="#000000" BlurRadius="12" ShadowDepth="4" Opacity="0.3" Direction="270"/>
    <DropShadowEffect x:Key="LightShadow" Color="#000000" BlurRadius="8" ShadowDepth="2" Opacity="0.2" Direction="270"/>
    <DropShadowEffect x:Key="GlowEffect" Color="#3DDC84" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>

    <!-- 默认 TextBlock 风格 -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
    </Style>

    <!-- 现代按钮风格 -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
        <Setter Property="Foreground" Value="#0A0E17"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource MediumRadius}"
                            Padding="{TemplateBinding Padding}"
                            Effect="{StaticResource LightShadow}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource PrimaryLightColor}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Background" Value="{StaticResource PrimaryDarkColor}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 次要按钮风格 -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource SurfaceElevatedColor}"/>
        <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource MediumRadius}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource SurfaceHighColor}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 危险按钮风格 -->
    <Style x:Key="DangerButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ErrorColor}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource MediumRadius}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource ErrorLightColor}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 现代 TextBox 风格 -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource SurfaceHighColor}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderLightColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,12"/>
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource MediumRadius}">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource BorderLightColor}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- PasswordBox 风格 -->
    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{StaticResource SurfaceHighColor}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderLightColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,12"/>
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource MediumRadius}">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource BorderLightColor}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CheckBox 风格 -->
    <Style TargetType="CheckBox">
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
    </Style>

    <!-- ListView 风格 -->
    <Style TargetType="ListView">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- 卡片容器风格 -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
        <Setter Property="CornerRadius" Value="{StaticResource LargeRadius}"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- 标签风格 -->
    <Style x:Key="LabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryColor}"/>
    </Style>

    <!-- 标题风格 -->
    <Style x:Key="TitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
    </Style>

    <!-- ContextMenu 深色主题风格 -->
    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="{StaticResource SurfaceElevatedColor}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderLightColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="HasDropShadow" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource MediumRadius}"
                            Effect="{StaticResource CardShadow}"
                            Padding="{TemplateBinding Padding}">
                        <ItemsPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- MenuItem 深色主题风格 -->
    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="{StaticResource SmallRadius}">
                        <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
                            <Setter Property="Foreground" Value="#0A0E17"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Separator 深色主题风格 -->
    <Style TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource BorderLightColor}"/>
        <Setter Property="Margin" Value="8,4"/>
        <Setter Property="Height" Value="1"/>
    </Style>

</ResourceDictionary>
