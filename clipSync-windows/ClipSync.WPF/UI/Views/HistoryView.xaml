<UserControl x:Class="ClipSync.WPF.UI.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部操作条 -->
        <Border Grid.Row="0" 
                Background="{StaticResource SurfaceElevatedColor}" 
                CornerRadius="{StaticResource MediumRadius}" 
                Padding="16" 
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- 标题 -->
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <TextBlock Text="📋" FontSize="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="Clipboard History" 
                              Style="{StaticResource TitleStyle}" 
                              FontSize="20"
                              VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- 操作按钮 -->
                <StackPanel Orientation="Horizontal" Grid.Column="1">
                    <Button x:Name="RefreshButton" 
                           Content="⟳ Refresh" 
                           Margin="0,0,8,0" 
                           Padding="12,6"
                           Style="{StaticResource SecondaryButtonStyle}"/>
                    <Button x:Name="ClearButton" 
                           Content="✕ Clear" 
                           Padding="12,6"
                           Style="{StaticResource DangerButtonStyle}"
                           Opacity="0.8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 历史记录列表 -->
        <ListView x:Name="HistoryList" 
                  Grid.Row="1" 
                  BorderThickness="0"
                  SnapsToDevicePixels="True"
                  UseLayoutRounding="True"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="16" 
                            Margin="0,4" 
                            Background="{StaticResource SurfaceElevatedColor}" 
                            CornerRadius="{StaticResource MediumRadius}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Effect" Value="{StaticResource LightShadow}"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 图标/图片预览 -->
                            <Border Grid.Column="0" 
                                   Width="48" 
                                   Height="48" 
                                   CornerRadius="{StaticResource SmallRadius}"
                                   Background="{StaticResource PrimaryColor}"
                                   Opacity="0.15"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ContentType}" Value="image">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="📄" 
                                          FontSize="20" 
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                            </Border>

                            <!-- 图片缩略图 -->
                            <Border Grid.Column="0" 
                                   Width="80" 
                                   Height="60"
                                   CornerRadius="{StaticResource SmallRadius}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"
                                   ClipToBounds="True">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ContentType}" Value="image">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.Background>
                                    <ImageBrush Stretch="UniformToFill">
                                        <ImageBrush.ImageSource>
                                            <MultiBinding Converter="{StaticResource ImagePreviewConverter}">
                                                <Binding Path="Content"/>
                                                <Binding Path="Format"/>
                                            </MultiBinding>
                                        </ImageBrush.ImageSource>
                                    </ImageBrush>
                                </Border.Background>
                            </Border>

                            <!-- 内容信息 -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock MaxWidth="500" 
                                          TextTrimming="CharacterEllipsis" 
                                          FontWeight="Medium"
                                          FontSize="14"
                                          Foreground="{StaticResource TextColor}"
                                          HorizontalAlignment="Left">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Content}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ContentType}" Value="image">
                                                    <Setter Property="Text" Value="{Binding Format, StringFormat='🖼️ Image ({0})'}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock FontSize="12" 
                                          Foreground="{StaticResource TextSecondaryColor}" 
                                          Margin="0,4,0,0">
                                    <Run Text="{Binding SourceDeviceName}"/>
                                    <Run Text=" • "/>
                                    <Run Text="{Binding ContentType}"/>
                                    <Run Text=" • "/>
                                    <Run Text="{Binding CreatedAt, Converter={StaticResource UnixTimestampConverter}}"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- 格式标签 -->
                            <Border Grid.Column="2" 
                                   Background="{StaticResource SurfaceHighColor}"
                                   CornerRadius="{StaticResource SmallRadius}"
                                   Padding="8,4"
                                   VerticalAlignment="Center" 
                                   Margin="12,0"
                                   BorderBrush="{StaticResource BorderLightColor}"
                                   BorderThickness="1">
                                <TextBlock Text="{Binding Format}" 
                                          FontSize="11" 
                                          Foreground="{StaticResource TextSecondaryColor}"
                                          FontWeight="Medium"/>
                            </Border>

                            <!-- 复制按钮 -->
                            <Button Grid.Column="3" 
                                   Content="📋 Copy" 
                                   Padding="12,6" 
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Tag="{Binding}"
                                   Style="{StaticResource SecondaryButtonStyle}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
            
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="SnapsToDevicePixels" Value="True"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter SnapsToDevicePixels="True"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- 空状态提示 -->
        <Border Grid.Row="1" 
               VerticalAlignment="Center" 
               HorizontalAlignment="Center"
               x:Name="EmptyText">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HistoryItems.Count, ElementName=HistoryList}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="📭" 
                          FontSize="64" 
                          HorizontalAlignment="Center" 
                          Margin="0,0,0,16"/>
                <TextBlock Text="No clipboard history yet" 
                          HorizontalAlignment="Center" 
                          Foreground="{StaticResource TextSecondaryColor}" 
                          FontSize="16"
                          FontWeight="Medium"/>
                <TextBlock Text="Copy something to get started" 
                          HorizontalAlignment="Center" 
                          Foreground="{StaticResource TextMutedColor}" 
                          FontSize="14"
                          Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
