<UserControl x:Class="ClipSync.WPF.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="20">
        <StackPanel MaxWidth="500">
            <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,24"/>

            <TextBlock Text="Server Configuration" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <TextBlock Text="WebSocket URL" FontWeight="Medium" Margin="0,0,0,4"/>
            <TextBox x:Name="ServerUrlBox" Margin="0,0,0,12" Padding="8"/>

            <TextBlock Text="HTTP URL" FontWeight="Medium" Margin="0,0,0,4"/>
            <TextBox x:Name="HttpUrlBox" Margin="0,0,0,24" Padding="8"/>

            <TextBlock Text="Preferences" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <CheckBox x:Name="AutoStartCheck" Content="Start with Windows" Margin="0,0,0,8"/>
            <CheckBox x:Name="SyncEnabledCheck" Content="Enable Clipboard Sync" Margin="0,0,0,8"/>
            <CheckBox x:Name="EncryptionEnabledCheck" Content="Enable Encryption (AES-256)" Margin="0,0,0,8"/>
            <CheckBox x:Name="MinimizeToTrayCheck" Content="Minimize to Tray on Close" Margin="0,0,0,24"/>

            <TextBlock Text="Device" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <TextBlock Text="Device Name" FontWeight="Medium" Margin="0,0,0,4"/>
            <TextBox x:Name="DeviceNameBox" Margin="0,0,0,24" Padding="8"/>

            <TextBlock Text="Account" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <TextBlock x:Name="UsernameText" FontSize="14" Margin="0,0,0,12"/>

            <Button x:Name="SaveButton" Content="Save Settings" Width="150" HorizontalAlignment="Left"
                    Padding="16,8" Background="#0078D4" Foreground="White" BorderThickness="0" Cursor="Hand"/>

            <Button x:Name="LogoutButton" Content="Logout" Width="150" HorizontalAlignment="Left"
                    Padding="16,8" Margin="0,12,0,0" Background="#CC0000" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
