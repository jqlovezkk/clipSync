<Application x:Class="ClipSync.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ClipSync.WPF.Converters"
>
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Converters -->
            <converters:ImagePreviewConverter x:Key="ImagePreviewConverter"/>
            <converters:UnixTimestampConverter x:Key="UnixTimestampConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
